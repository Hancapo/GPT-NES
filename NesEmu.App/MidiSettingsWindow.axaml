<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="NesEmu.App.MidiSettingsWindow"
        Width="820"
        Height="760"
        MinWidth="720"
        MinHeight="640"
        Background="#202020"
        Foreground="#F4F4F4"
        FontFamily="Segoe UI"
        Title="Configuración MIDI"
        WindowStartupLocation="CenterOwner">
  <Window.Styles>
    <Style Selector="Border.section">
      <Setter Property="Background" Value="#262626" />
      <Setter Property="BorderBrush" Value="#3A3A3A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.help">
      <Setter Property="Opacity" Value="0.72" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="ComboBox.form">
      <Setter Property="MinWidth" Value="260" />
    </Style>
    <Style Selector="Slider.volume">
      <Setter Property="Width" Value="150" />
      <Setter Property="Minimum" Value="0" />
      <Setter Property="Maximum" Value="200" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#2B2B2B"
            BorderBrush="#3A3A3A"
            BorderThickness="0,0,0,1"
            Padding="18,14">
      <StackPanel Spacing="4">
        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   Text="Conversión NES a MIDI OUT" />
        <TextBlock Classes="help"
                   Text="Los canales Pulse 1, Pulse 2 y Triangle se convierten a notas MIDI; Noise y DMC se simplifican como percusión." />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="16" Spacing="16">
        <Border Classes="section">
          <StackPanel Spacing="12">
            <TextBlock Classes="section-title" Text="Salida" />

            <CheckBox x:Name="EnableMidiCheckBox"
                      Content="Activar salida MIDI en tiempo real" />

            <Grid ColumnDefinitions="170,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
              <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Dispositivo" />
              <ComboBox x:Name="OutputDeviceComboBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form" />

              <TextBlock Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Classes="help"
                         Text="Si activas esta función, el teclado o módulo MIDI recibirá la música del juego en tiempo real." />

              <CheckBox x:Name="MusicOnlyCheckBox"
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Content="Intentar filtrar efectos cortos para dejar solo la música" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="section">
          <StackPanel Spacing="12">
            <TextBlock Classes="section-title" Text="Canales Melódicos" />
            <TextBlock Classes="help"
                       Text="Pulse 1, Pulse 2 y Triangle salen por los canales MIDI 1, 2 y 3 con pitch bend para afinar mejor las notas." />

            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
              <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Text="Canal" />
              <TextBlock Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Text="Instrumento" />
              <TextBlock Grid.Row="0" Grid.Column="3" FontWeight="SemiBold" Text="Volumen" />

              <CheckBox x:Name="Pulse1EnabledCheckBox" Grid.Row="1" Content="Pulse 1" />
              <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="MIDI 1" />
              <ComboBox x:Name="Pulse1ProgramComboBox"
                        Grid.Row="1"
                        Grid.Column="2"
                        Classes="form" />
              <StackPanel Grid.Row="1"
                          Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="Pulse1VolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="Pulse1VolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <CheckBox x:Name="Pulse2EnabledCheckBox" Grid.Row="2" Content="Pulse 2" />
              <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="MIDI 2" />
              <ComboBox x:Name="Pulse2ProgramComboBox"
                        Grid.Row="2"
                        Grid.Column="2"
                        Classes="form" />
              <StackPanel Grid.Row="2"
                          Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="Pulse2VolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="Pulse2VolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <CheckBox x:Name="TriangleEnabledCheckBox" Grid.Row="3" Content="Triangle" />
              <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="MIDI 3" />
              <ComboBox x:Name="TriangleProgramComboBox"
                        Grid.Row="3"
                        Grid.Column="2"
                        Classes="form" />
              <StackPanel Grid.Row="3"
                          Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="TriangleVolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="TriangleVolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="section">
          <StackPanel Spacing="12">
            <TextBlock Classes="section-title" Text="Percusión" />
            <TextBlock Classes="help"
                       Text="Noise y DMC salen por el canal MIDI 10. Puedes dejar Auto o forzar un sonido de batería concreto." />

            <CheckBox x:Name="PercussionCheckBox"
                      Content="Enviar Noise y DMC como percusión" />

            <Grid ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
              <CheckBox x:Name="NoiseEnabledCheckBox" Grid.Row="0" Content="Noise" />
              <ComboBox x:Name="NoiseDrumComboBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form" />
              <StackPanel Grid.Row="0"
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="NoiseVolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="NoiseVolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <CheckBox x:Name="DmcEnabledCheckBox" Grid.Row="1" Content="DMC" />
              <ComboBox x:Name="DmcDrumComboBox"
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="form" />
              <StackPanel Grid.Row="1"
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="DmcVolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="DmcVolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <TextBlock Grid.Row="2"
                         Grid.ColumnSpan="3"
                         Classes="help"
                         Text="La separación música/SFX aquí es heurística. Está pensada para priorizar líneas musicales estables y percusión del tema." />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="#2B2B2B"
            BorderBrush="#3A3A3A"
            BorderThickness="0,1,0,0"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <TextBlock VerticalAlignment="Center"
                   Classes="help"
                   Text="Puedes aplicar los cambios con la emulación en marcha." />
        <Button Grid.Column="1"
                MinWidth="96"
                Content="Cancelar"
                Click="CancelButton_OnClick" />
        <Button Grid.Column="2"
                MinWidth="96"
                Classes="accent"
                Content="Aceptar"
                Click="AcceptButton_OnClick" />
      </Grid>
    </Border>
  </Grid>
</Window>
