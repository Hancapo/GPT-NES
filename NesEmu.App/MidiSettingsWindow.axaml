<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="NesEmu.App.MidiSettingsWindow"
        Width="820"
        Height="760"
        MinWidth="720"
        MinHeight="640"
        Background="#202020"
        Foreground="#F4F4F4"
        FontFamily="Segoe UI"
        Title="MIDI Settings"
        WindowStartupLocation="CenterOwner">
  <Window.Styles>
    <Style Selector="Border.section">
      <Setter Property="Background" Value="#262626" />
      <Setter Property="BorderBrush" Value="#3A3A3A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.help">
      <Setter Property="Opacity" Value="0.72" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="ComboBox.form">
      <Setter Property="MinWidth" Value="260" />
    </Style>
    <Style Selector="Slider.volume">
      <Setter Property="Width" Value="150" />
      <Setter Property="Minimum" Value="0" />
      <Setter Property="Maximum" Value="200" />
    </Style>
    <Style Selector="Slider.sync-offset">
      <Setter Property="Width" Value="220" />
      <Setter Property="Minimum" Value="-40" />
      <Setter Property="Maximum" Value="40" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#2B2B2B"
            BorderBrush="#3A3A3A"
            BorderThickness="0,0,0,1"
            Padding="18,14">
      <StackPanel Spacing="4">
        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   Text="NES to MIDI OUT" />
        <TextBlock Classes="help"
                   Text="Pulse 1, Pulse 2, and Triangle are converted to MIDI notes. Noise and DMC are simplified as percussion." />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="16" Spacing="16">
        <Border Classes="section">
          <StackPanel Spacing="12">
            <TextBlock Classes="section-title" Text="Output" />

            <CheckBox x:Name="EnableMidiCheckBox"
                      Content="Enable real-time MIDI output" />

            <Grid ColumnDefinitions="170,*"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
              <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Device" />
              <ComboBox x:Name="OutputDeviceComboBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form" />

              <TextBlock Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Classes="help"
                         Text="When enabled, your keyboard or MIDI module will receive the game's music in real time." />

              <Grid Grid.Row="2"
                    Grid.ColumnSpan="2"
                    ColumnDefinitions="170,Auto,Auto"
                    ColumnSpacing="12">
                <TextBlock VerticalAlignment="Center" Text="MIDI sync offset" />
                <Slider x:Name="MidiSyncOffsetSlider"
                        Grid.Column="1"
                        Classes="sync-offset"
                        ValueChanged="SyncOffsetSlider_OnValueChanged" />
                <TextBlock x:Name="MidiSyncOffsetText"
                           Grid.Column="2"
                           Width="64"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </Grid>
              <TextBlock Grid.Row="3"
                         Grid.ColumnSpan="2"
                         Classes="help"
                         Text="Negative values send MIDI earlier. Positive values delay MIDI further." />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="section">
          <StackPanel Spacing="12">
            <TextBlock Classes="section-title" Text="Melodic Channels" />
            <TextBlock Classes="help"
                       Text="Pulse 1, Pulse 2, and Triangle are sent through MIDI channels 1, 2, and 3 with pitch bend for closer tuning." />

            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
              <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Text="Channel" />
              <TextBlock Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Text="Instrument" />
              <TextBlock Grid.Row="0" Grid.Column="3" FontWeight="SemiBold" Text="Volume" />

              <CheckBox x:Name="Pulse1EnabledCheckBox" Grid.Row="1" Content="Pulse 1" />
              <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="MIDI 1" />
              <ComboBox x:Name="Pulse1ProgramComboBox"
                        Grid.Row="1"
                        Grid.Column="2"
                        Classes="form" />
              <StackPanel Grid.Row="1"
                          Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="Pulse1VolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="Pulse1VolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <CheckBox x:Name="Pulse2EnabledCheckBox" Grid.Row="2" Content="Pulse 2" />
              <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="MIDI 2" />
              <ComboBox x:Name="Pulse2ProgramComboBox"
                        Grid.Row="2"
                        Grid.Column="2"
                        Classes="form" />
              <StackPanel Grid.Row="2"
                          Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="Pulse2VolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="Pulse2VolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <CheckBox x:Name="TriangleEnabledCheckBox" Grid.Row="3" Content="Triangle" />
              <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="MIDI 3" />
              <ComboBox x:Name="TriangleProgramComboBox"
                        Grid.Row="3"
                        Grid.Column="2"
                        Classes="form" />
              <StackPanel Grid.Row="3"
                          Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="TriangleVolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="TriangleVolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="section">
          <StackPanel Spacing="12">
            <TextBlock Classes="section-title" Text="Percussion" />
            <TextBlock Classes="help"
                       Text="Noise and DMC are sent through MIDI channel 10. Leave them on Auto or force a specific drum note." />

            <CheckBox x:Name="PercussionCheckBox"
                      Content="Send Noise and DMC as percussion" />

            <Grid ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
              <CheckBox x:Name="NoiseEnabledCheckBox" Grid.Row="0" Content="Noise" />
              <ComboBox x:Name="NoiseDrumComboBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="form" />
              <StackPanel Grid.Row="0"
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="NoiseVolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="NoiseVolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <CheckBox x:Name="DmcEnabledCheckBox" Grid.Row="1" Content="DMC" />
              <ComboBox x:Name="DmcDrumComboBox"
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="form" />
              <StackPanel Grid.Row="1"
                          Grid.Column="2"
                          Orientation="Horizontal"
                          Spacing="8">
                <Slider x:Name="DmcVolumeSlider"
                        Classes="volume"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="DmcVolumeText"
                           Width="44"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />
              </StackPanel>

              <TextBlock Grid.Row="2"
                         Grid.ColumnSpan="3"
                         Classes="help"
                         Text="Noise and DMC stay on MIDI channel 10, with either automatic drum mapping or the note you choose." />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="#2B2B2B"
            BorderBrush="#3A3A3A"
            BorderThickness="0,1,0,0"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <TextBlock VerticalAlignment="Center"
                   Classes="help"
                   Text="You can apply changes while the emulator is running." />
        <Button Grid.Column="1"
                MinWidth="96"
                Content="Cancel"
                Click="CancelButton_OnClick" />
        <Button Grid.Column="2"
                MinWidth="96"
                Classes="accent"
                Content="Apply"
                Click="AcceptButton_OnClick" />
      </Grid>
    </Border>
  </Grid>
</Window>
