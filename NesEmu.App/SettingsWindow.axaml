<shadui:Window xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
               mc:Ignorable="d"
               x:Class="NesEmu.App.SettingsWindow"
               Width="1040"
               Height="820"
               MinWidth="900"
               MinHeight="720"
               Title="Settings"
               TitleFontWeight="SemiBold"
               ShowInTaskbar="False"
               WindowStartupLocation="CenterOwner">
  <shadui:Window.Styles>
    <Style Selector="TextBlock.help">
      <Setter Property="Opacity" Value="0.72" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.group-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ComboBox.setting-combo">
      <Setter Property="MinWidth" Value="220" />
    </Style>
    <Style Selector="Button.key-binding">
      <Setter Property="MinWidth" Value="200" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Slider.channel-slider">
      <Setter Property="Minimum" Value="0" />
      <Setter Property="Maximum" Value="200" />
      <Setter Property="Width" Value="160" />
    </Style>
    <Style Selector="Border.section">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="shadui|SidebarItem">
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
  </shadui:Window.Styles>

  <shadui:Window.LogoContent>
    <Border Margin="12,8,0,8"
            Padding="10,4"
            CornerRadius="999"
            Background="{DynamicResource PrimaryColor}">
    </Border>
  </shadui:Window.LogoContent>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="24,24,24,20">
    <Grid Grid.Row="1"
          ColumnDefinitions="220,18,*">
      <Border Classes="section"
              Grid.Column="0"
              Padding="12">
        <shadui:Sidebar Expanded="True"
                        Width="196"
                        Background="Transparent">
          <StackPanel Spacing="4">
            <shadui:SidebarItem x:Name="VideoSectionItem"
                                Tag="Video"
                                Content="Video"
                                IsChecked="True"
                                Checked="SettingsSectionItem_OnChecked" />
            <shadui:SidebarItem x:Name="AudioSectionItem"
                                Tag="Audio"
                                Content="Audio"
                                Checked="SettingsSectionItem_OnChecked" />
            <shadui:SidebarItem x:Name="ControlsSectionItem"
                                Tag="Controls"
                                Content="Controls"
                                Checked="SettingsSectionItem_OnChecked" />
            <shadui:SidebarItem x:Name="MidiSectionItem"
                                Tag="MIDI"
                                Content="MIDI"
                                Checked="SettingsSectionItem_OnChecked" />
          </StackPanel>
        </shadui:Sidebar>
      </Border>

      <Border Classes="section"
              Grid.Column="2"
              Padding="0">
        <Grid>
          <ScrollViewer x:Name="VideoScrollViewer"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20"
                        Spacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="Video" />
                <TextBlock Classes="help"
                           Text="Renderer selection for the game viewport." />
              </StackPanel>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Video" />

                  <Grid ColumnDefinitions="170,*"
                        ColumnSpacing="16">
                    <TextBlock VerticalAlignment="Center" Text="Renderer" />
                    <ComboBox x:Name="VideoRendererComboBox"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="VideoSelection_OnChanged" />
                  </Grid>

                  <TextBlock x:Name="VideoRendererDescriptionText"
                             Classes="help" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer x:Name="AudioScrollViewer"
                        IsVisible="False"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="20"
                        Spacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="Audio" />
                <TextBlock Classes="help"
                           Text="Playback API, latency and volume for the emulator output." />
              </StackPanel>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Playback" />

                  <Grid ColumnDefinitions="170,*,Auto"
                        RowDefinitions="Auto,Auto,Auto"
                        ColumnSpacing="16"
                        RowSpacing="16">
                    <TextBlock VerticalAlignment="Center" Text="Audio API" />
                    <ComboBox x:Name="AudioApiComboBox"
                            Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Classes="setting-combo"
                              SelectionChanged="AudioSelection_OnChanged" />

                    <TextBlock Grid.Row="1"
                               VerticalAlignment="Center"
                               Text="Output latency" />
                    <Slider x:Name="AudioLatencySlider"
                            Grid.Row="1"
                            Grid.Column="1"
                            Minimum="40"
                            Maximum="240"
                            ValueChanged="AudioSlider_OnValueChanged" />
                    <TextBlock x:Name="AudioLatencyText"
                               Grid.Row="1"
                               Grid.Column="2"
                               Width="68"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />

                    <TextBlock Grid.Row="2"
                               VerticalAlignment="Center"
                               Text="Master volume" />
                    <Slider x:Name="AudioVolumeSlider"
                            Grid.Row="2"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="200"
                            ValueChanged="AudioSlider_OnValueChanged" />
                    <TextBlock x:Name="AudioVolumeText"
                               Grid.Row="2"
                               Grid.Column="2"
                               Width="68"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                  </Grid>

                  <TextBlock x:Name="AudioApiDescriptionText"
                             Classes="help" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer x:Name="ControlsScrollViewer"
                        IsVisible="False"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20"
                        Spacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="Controls" />
                <TextBlock Classes="help"
                           Text="Keyboard bindings and controller mapping." />
              </StackPanel>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Controller" />

                  <Grid ColumnDefinitions="170,*"
                        ColumnSpacing="16">
                    <TextBlock VerticalAlignment="Center" Text="Active controller" />
                    <ComboBox x:Name="ControllerDeviceComboBox"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="ControllerDeviceComboBox_OnSelectionChanged" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Keyboard bindings" />
                  <TextBlock x:Name="KeyboardCaptureText"
                             Classes="help"
                             Text="Click a command, then press the key you want to assign." />

                  <Grid ColumnDefinitions="Auto,*,Auto,*"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        ColumnSpacing="14"
                        RowSpacing="14">
                    <TextBlock VerticalAlignment="Center" Text="A" />
                    <Button x:Name="KeyboardAButton"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="A"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="B" />
                    <Button x:Name="KeyboardBButton"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="B"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Row="1"
                               VerticalAlignment="Center"
                               Text="Select" />
                    <Button x:Name="KeyboardSelectButton"
                            Grid.Row="1"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="Select"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="Start" />
                    <Button x:Name="KeyboardStartButton"
                            Grid.Row="1"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="Start"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Row="2"
                               VerticalAlignment="Center"
                               Text="Up" />
                    <Button x:Name="KeyboardUpButton"
                            Grid.Row="2"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="Up"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="Down" />
                    <Button x:Name="KeyboardDownButton"
                            Grid.Row="2"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="Down"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Row="3"
                               VerticalAlignment="Center"
                               Text="Left" />
                    <Button x:Name="KeyboardLeftButton"
                            Grid.Row="3"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="Left"
                            Click="KeyboardBindingButton_OnClick" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="Right" />
                    <Button x:Name="KeyboardRightButton"
                            Grid.Row="3"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="Right"
                            Click="KeyboardBindingButton_OnClick" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Controller bindings" />
                  <TextBlock x:Name="ControllerCaptureText"
                             Classes="help"
                             Text="Click a command, then press a controller button or move a stick." />

                  <Grid ColumnDefinitions="170,*"
                        ColumnSpacing="16">
                    <TextBlock VerticalAlignment="Center" Text="Analog D-Pad overlay" />
                    <ComboBox x:Name="ControllerAnalogDPadComboBox"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="InputSelection_OnChanged" />
                  </Grid>

                  <TextBlock Classes="help"
                             Text="Adds left or right stick directions on top of the mapped D-Pad inputs." />

                  <Grid ColumnDefinitions="Auto,*,Auto,*"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        ColumnSpacing="14"
                        RowSpacing="14">
                    <TextBlock VerticalAlignment="Center" Text="A" />
                    <Button x:Name="ControllerAButton"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="A"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="B" />
                    <Button x:Name="ControllerBButton"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="B"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Row="1"
                               VerticalAlignment="Center"
                               Text="Select" />
                    <Button x:Name="ControllerSelectButton"
                            Grid.Row="1"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="Select"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="Start" />
                    <Button x:Name="ControllerStartButton"
                            Grid.Row="1"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="Start"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Row="2"
                               VerticalAlignment="Center"
                               Text="Up" />
                    <Button x:Name="ControllerUpButton"
                            Grid.Row="2"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="Up"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="Down" />
                    <Button x:Name="ControllerDownButton"
                            Grid.Row="2"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="Down"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Row="3"
                               VerticalAlignment="Center"
                               Text="Left" />
                    <Button x:Name="ControllerLeftButton"
                            Grid.Row="3"
                            Grid.Column="1"
                            Classes="Outline key-binding"
                            Tag="Left"
                            Click="ControllerBindingButton_OnClick" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="Right" />
                    <Button x:Name="ControllerRightButton"
                            Grid.Row="3"
                            Grid.Column="3"
                            Classes="Outline key-binding"
                            Tag="Right"
                            Click="ControllerBindingButton_OnClick" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer x:Name="MidiScrollViewer"
                        IsVisible="False"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20"
                        Spacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="MIDI" />
                <TextBlock Classes="help"
                           Text="Real-time MIDI output and channel mapping." />
              </StackPanel>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Output" />

                  <Grid ColumnDefinitions="170,*,Auto"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                        ColumnSpacing="16"
                        RowSpacing="14">
                    <CheckBox x:Name="EnableMidiCheckBox"
                              Grid.ColumnSpan="3"
                              Content="Enable real-time MIDI output"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />

                    <TextBlock Grid.Row="1"
                               VerticalAlignment="Center"
                               Text="Device" />
                    <ComboBox x:Name="OutputDeviceComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Classes="setting-combo"
                              SelectionChanged="MidiSelection_OnChanged" />

                    <CheckBox x:Name="MusicOnlyCheckBox"
                              Grid.Row="2"
                              Grid.ColumnSpan="3"
                              Content="Filter short sound effects"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />

                    <CheckBox x:Name="PercussionCheckBox"
                              Grid.Row="3"
                              Grid.ColumnSpan="3"
                              Content="Send Noise and DMC as percussion"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />

                    <TextBlock Grid.Row="4"
                               VerticalAlignment="Center"
                               Text="Sync offset" />
                    <Slider x:Name="MidiSyncOffsetSlider"
                            Grid.Row="4"
                            Grid.Column="1"
                            Minimum="-40"
                            Maximum="40"
                            ValueChanged="MidiSlider_OnValueChanged" />
                    <TextBlock x:Name="MidiSyncOffsetText"
                               Grid.Row="4"
                               Grid.Column="2"
                               Width="72"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Melodic channels" />

                  <Grid ColumnDefinitions="Auto,*,Auto"
                        RowDefinitions="Auto,Auto,Auto"
                        ColumnSpacing="16"
                        RowSpacing="14">
                    <CheckBox x:Name="Pulse1EnabledCheckBox"
                              Content="Pulse 1"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />
                    <ComboBox x:Name="Pulse1ProgramComboBox"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="MidiSelection_OnChanged" />
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10">
                      <Slider x:Name="Pulse1VolumeSlider"
                              Classes="channel-slider"
                              ValueChanged="MidiSlider_OnValueChanged" />
                      <TextBlock x:Name="Pulse1VolumeText"
                                 Width="44"
                                 VerticalAlignment="Center"
                                 TextAlignment="Right" />
                    </StackPanel>

                    <CheckBox x:Name="Pulse2EnabledCheckBox"
                              Grid.Row="1"
                              Content="Pulse 2"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />
                    <ComboBox x:Name="Pulse2ProgramComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="MidiSelection_OnChanged" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10">
                      <Slider x:Name="Pulse2VolumeSlider"
                              Classes="channel-slider"
                              ValueChanged="MidiSlider_OnValueChanged" />
                      <TextBlock x:Name="Pulse2VolumeText"
                                 Width="44"
                                 VerticalAlignment="Center"
                                 TextAlignment="Right" />
                    </StackPanel>

                    <CheckBox x:Name="TriangleEnabledCheckBox"
                              Grid.Row="2"
                              Content="Triangle"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />
                    <ComboBox x:Name="TriangleProgramComboBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="MidiSelection_OnChanged" />
                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10">
                      <Slider x:Name="TriangleVolumeSlider"
                              Classes="channel-slider"
                              ValueChanged="MidiSlider_OnValueChanged" />
                      <TextBlock x:Name="TriangleVolumeText"
                                 Width="44"
                                 VerticalAlignment="Center"
                                 TextAlignment="Right" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="section">
                <StackPanel Spacing="16">
                  <TextBlock Classes="group-title" Text="Percussion" />

                  <Grid ColumnDefinitions="Auto,*,Auto"
                        RowDefinitions="Auto,Auto"
                        ColumnSpacing="16"
                        RowSpacing="14">
                    <CheckBox x:Name="NoiseEnabledCheckBox"
                              Content="Noise"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />
                    <ComboBox x:Name="NoiseDrumComboBox"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="MidiSelection_OnChanged" />
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10">
                      <Slider x:Name="NoiseVolumeSlider"
                              Classes="channel-slider"
                              ValueChanged="MidiSlider_OnValueChanged" />
                      <TextBlock x:Name="NoiseVolumeText"
                                 Width="44"
                                 VerticalAlignment="Center"
                                 TextAlignment="Right" />
                    </StackPanel>

                    <CheckBox x:Name="DmcEnabledCheckBox"
                              Grid.Row="1"
                              Content="DMC"
                              Checked="MidiToggle_OnChanged"
                              Unchecked="MidiToggle_OnChanged" />
                    <ComboBox x:Name="DmcDrumComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Classes="setting-combo"
                              SelectionChanged="MidiSelection_OnChanged" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10">
                      <Slider x:Name="DmcVolumeSlider"
                              Classes="channel-slider"
                              ValueChanged="MidiSlider_OnValueChanged" />
                      <TextBlock x:Name="DmcVolumeText"
                                 Width="44"
                                 VerticalAlignment="Center"
                                 TextAlignment="Right" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2"
            Classes="section"
            Padding="16,12"
            Margin="0,18,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="10">
        <TextBlock VerticalAlignment="Center"
                   Classes="help"
                   Text="Changes are applied immediately." />
        <Button Grid.Column="1"
                MinWidth="132"
                Classes="Outline"
                Content="Restore defaults"
                Click="RestoreDefaultsButton_OnClick" />
        <Button Grid.Column="2"
                MinWidth="104"
                Classes="Primary"
                IsDefault="True"
                Content="Close"
                Click="CloseButton_OnClick" />
      </Grid>
    </Border>
  </Grid>
</shadui:Window>
