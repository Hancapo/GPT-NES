<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="NesEmu.App.MainWindow"
        Width="1200"
        Height="820"
        MinWidth="860"
        MinHeight="620"
        Background="#1C1F23"
        Foreground="#F3F3F3"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        Title="NesEmu">
  <Window.Styles>
    <Style Selector="Border.frame-host">
      <Setter Property="Background" Value="#111315" />
      <Setter Property="BorderBrush" Value="#31353A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="TextBlock.status">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,14,0" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="_Open ROM..." Click="OpenRomButton_OnClick" />
        <Separator />
        <MenuItem Header="_Exit" Click="ExitMenuItem_OnClick" />
      </MenuItem>
      <MenuItem Header="_Emulation">
        <MenuItem x:Name="PauseMenuItem" Header="_Pause" Click="PauseButton_OnClick" />
        <MenuItem x:Name="StopMenuItem" Header="_Stop" Click="StopButton_OnClick" />
        <MenuItem x:Name="ResetMenuItem" Header="_Reset" Click="ResetButton_OnClick" />
      </MenuItem>
      <MenuItem Header="_Settings" Click="SettingsMenuItem_OnClick" />
    </Menu>

    <Border Grid.Row="1"
            Margin="12"
            Classes="frame-host"
            Padding="12">
      <Grid>
        <Border x:Name="GameViewport"
                Background="#08090A"
                BorderBrush="#23272C"
                BorderThickness="1"
                CornerRadius="6"
                Focusable="True"
                PointerPressed="GameViewport_OnPointerPressed">
          <Grid>
            <Viewbox Stretch="Uniform"
                     StretchDirection="Both"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     RenderOptions.BitmapInterpolationMode="None">
              <Border Background="#000000"
                      BorderBrush="#1B2025"
                      BorderThickness="14"
                      CornerRadius="4">
                <Image x:Name="GameImage"
                       Width="256"
                       Height="240"
                       Stretch="Fill"
                       RenderOptions.BitmapInterpolationMode="None" />
              </Border>
            </Viewbox>

            <Border x:Name="OverlayPanel"
                    Width="320"
                    Padding="18"
                    CornerRadius="10"
                    Background="#D9181A1D"
                    BorderBrush="#43484E"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <StackPanel Spacing="12">
                <TextBlock x:Name="OverlayTitleText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Text="NesEmu" />
                <TextBlock x:Name="OverlayBodyText"
                           TextAlignment="Center"
                           Opacity="0.78"
                           Text="Open a NES ROM to get started." />
                <Button x:Name="OverlayOpenButton"
                        HorizontalAlignment="Center"
                        Width="124"
                        Content="Open ROM"
                        Click="OpenRomButton_OnClick" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Background="#25292E"
            BorderBrush="#31353A"
            BorderThickness="0,1,0,0"
            Padding="12,7">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Left"
                    Orientation="Horizontal">
          <TextBlock x:Name="RunStateText" Classes="status" Text="No ROM" />
          <TextBlock x:Name="FpsText" Classes="status" Text="FPS: 0.0" />
          <TextBlock x:Name="RomText" Classes="status" Text="ROM: -" />
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Opacity="0.76"
                   Text="Ready." />
      </DockPanel>
    </Border>
  </Grid>
</Window>
