<shadui:Window xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:NesEmu.App"
               xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
               mc:Ignorable="d"
               x:Class="NesEmu.App.MainWindow"
               Width="1280"
               Height="900"
               MinWidth="980"
               MinHeight="720"
               Title="{Binding WindowTitle}"
               TitleFontWeight="SemiBold"
               IsMenuVisible="True"
               SaveWindowState="True"
               ShowBottomBorder="True"
               UseLayoutRounding="True"
               WindowStartupLocation="CenterScreen">
  <shadui:Window.Styles>
    <Style Selector="Border.surface">
      <Setter Property="Background" Value="#FF0B0F14" />
      <Setter Property="BorderBrush" Value="#FF202B38" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>
    <Style Selector="Border.footer-panel">
      <Setter Property="Background" Value="#FF0F141B" />
      <Setter Property="BorderBrush" Value="#FF243140" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Border.footer-icon">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="#FF161D27" />
      <Setter Property="BorderBrush" Value="#FF2C3A4D" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Path.footer-icon-path">
      <Setter Property="Fill" Value="#FFE3ECF7" />
      <Setter Property="Stretch" Value="Uniform" />
    </Style>
    <Style Selector="TextBlock.footer-label">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.54" />
    </Style>
    <Style Selector="TextBlock.footer-value">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="Button.volume-step">
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Slider.footer-volume">
      <Setter Property="Minimum" Value="0" />
      <Setter Property="Maximum" Value="200" />
      <Setter Property="Width" Value="110" />
    </Style>
  </shadui:Window.Styles>

  <shadui:Window.LogoContent>
    <Border Margin="12,8,0,8"
            Width="30"
            Height="30"
            CornerRadius="8"
            Background="#FF17212C"
            BorderBrush="#FF2B394D"
            BorderThickness="1">
      <TextBlock HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="12"
                 FontWeight="Bold"
                 Foreground="#FFE8EEF6"
                 Text="N" />
    </Border>
  </shadui:Window.LogoContent>

  <shadui:Window.MenuBarContent>
    <Menu>
      <MenuItem Header="File">
        <MenuItem Header="Open ROM..." Click="OpenRomButton_OnClick" />
        <Separator />
        <MenuItem Header="Exit" Click="ExitMenuItem_OnClick" />
      </MenuItem>
      <MenuItem Header="Emulation">
        <MenuItem x:Name="PauseMenuItem"
                  Header="{Binding PauseMenuHeader}"
                  IsEnabled="{Binding TransportEnabled}"
                  Click="PauseButton_OnClick" />
        <MenuItem x:Name="StopMenuItem"
                  Header="Stop"
                  IsEnabled="{Binding StopEnabled}"
                  Click="StopButton_OnClick" />
        <MenuItem x:Name="ResetMenuItem"
                  Header="Reset"
                  IsEnabled="{Binding ResetEnabled}"
                  Click="ResetButton_OnClick" />
      </MenuItem>
      <MenuItem Header="View">
        <MenuItem x:Name="FullscreenMenuItem"
                  Header="{Binding FullscreenMenuHeader}"
                  Click="FullscreenMenuItem_OnClick" />
      </MenuItem>
      <MenuItem Header="Tools">
        <MenuItem Header="Open Log Folder" Click="OpenLogFolderMenuItem_OnClick" />
      </MenuItem>
      <MenuItem Header="Settings" Click="SettingsMenuItem_OnClick" />
    </Menu>
  </shadui:Window.MenuBarContent>

  <Grid x:Name="RootLayoutGrid"
        RowDefinitions="*,Auto"
        Margin="24,22,24,20">
    <Border x:Name="ViewportShellBorder"
            Classes="surface"
            Padding="18">
      <Grid>
        <Border CornerRadius="12"
                Background="#FF0D1218" />

        <Border Margin="12"
                CornerRadius="12"
                BorderBrush="#141B23"
                BorderThickness="1"
                Background="#0A0E13" />

        <Border x:Name="GameViewport"
                Focusable="True"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="#2B3440"
                Background="#05080A"
                Padding="24"
                PointerPressed="GameViewport_OnPointerPressed">
          <Grid>
            <Viewbox Stretch="Uniform"
                     StretchDirection="Both"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     RenderOptions.BitmapInterpolationMode="None">
              <Border Background="#030508"
                      BorderBrush="#1B2430"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="18">
                <Grid Width="256"
                      Height="240">
                  <Image x:Name="GameImage"
                         Stretch="Fill"
                         RenderOptions.BitmapInterpolationMode="None" />
                  <local:NesOpenGlControl x:Name="OpenGlGameView"
                                          IsVisible="False"
                                          Width="256"
                                          Height="240" />
                </Grid>
              </Border>
            </Viewbox>

            <Border x:Name="OverlayPanel"
                    IsVisible="{Binding OverlayVisible}"
                    Width="336"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#EE10151C"
                    BorderBrush="#FF293646"
                    BorderThickness="1"
                    CornerRadius="10">
              <StackPanel Spacing="14">
                <Border Width="42"
                        Height="42"
                        HorizontalAlignment="Center"
                        CornerRadius="10"
                        Background="#FF17212C"
                        BorderBrush="#FF2C3A4D"
                        BorderThickness="1">
                  <Path Width="18"
                        Height="18"
                        Classes="footer-icon-path"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M5,3 H19 C20.1,3 21,3.9 21,5 V19 C21,20.1 20.1,21 19,21 H5 C3.9,21 3,20.1 3,19 V5 C3,3.9 3.9,3 5,3 Z M7,6 H17 V9 H7 Z M8,12 H10 V17 H8 Z M14,12 H16 V17 H14 Z" />
                </Border>
                <TextBlock x:Name="OverlayTitleText"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Text="{Binding OverlayTitle}" />
                <TextBlock x:Name="OverlayBodyText"
                           FontSize="14"
                           Opacity="0.74"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Text="{Binding OverlayBody}" />
                <Button x:Name="OverlayOpenButton"
                        IsVisible="{Binding OverlayOpenButtonVisible}"
                        Classes="Primary"
                        MinWidth="150"
                        HorizontalAlignment="Center"
                        Content="Open ROM..."
                        Click="OpenRomButton_OnClick" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="StatusPanelBorder"
            Grid.Row="1"
            Classes="footer-panel"
            Padding="14,10"
            Margin="0,16,0,0">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="18">
        <Grid ColumnDefinitions="220,90,*,120,220"
              ColumnSpacing="16">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M5,3 H19 C20.1,3 21,3.9 21,5 V19 C21,20.1 20.1,21 19,21 H5 C3.9,21 3,20.1 3,19 V5 C3,3.9 3.9,3 5,3 Z M7,6 H17 V9 H7 Z M8,12 H10 V17 H8 Z M14,12 H16 V17 H14 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="ROM" />
              <TextBlock x:Name="RomText"
                         Classes="footer-value"
                         Text="{Binding RomText}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Column="1"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M4,19 H7 V12 H4 Z M10,19 H13 V9 H10 Z M16,19 H19 V5 H16 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="FPS" />
              <TextBlock x:Name="FpsText"
                         Classes="footer-value"
                         Text="{Binding FpsText}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Column="2"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M15,4 V14.5 A3.5,3.5 0 1 1 13,11.35 V7 H9 V16.5 A3.5,3.5 0 1 1 7,13.35 V4 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="MIDI OUTPUT" />
              <TextBlock x:Name="MidiDeviceText"
                         Classes="footer-value"
                         Text="{Binding MidiDeviceText}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Column="3"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M4,5 H20 V15 H4 Z M10,17 H14 V19 H10 Z M8,20 H16 V21 H8 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="RENDERER" />
              <TextBlock x:Name="RendererText"
                         Classes="footer-value"
                         Text="{Binding RendererText}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Column="4"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M4,10 H8 L12,6 V18 L8,14 H4 Z M14,10 H16 V14 H14 Z M18,8 H20 V16 H18 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="2"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="GAME VOLUME" />
              <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                    ColumnSpacing="8">
                <Slider x:Name="FooterVolumeSlider"
                        Grid.Column="1"
                        Classes="footer-volume"
                        ValueChanged="FooterVolumeSlider_OnValueChanged" />
                <TextBlock x:Name="VolumeText"
                           Grid.Column="2"
                           Width="40"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           TextAlignment="Right"
                           Text="{Binding VolumeText}" />
              </Grid>
            </StackPanel>
          </Grid>
        </Grid>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M4,5 H20 V15 H4 Z M9,17 H15 V19 H9 Z M7,20 H17 V21 H7 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="OS" />
              <TextBlock x:Name="OsText"
                         Classes="footer-value"
                         Width="118"
                         Text="{Binding OsText}" />
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="10">
            <Border Classes="footer-icon">
              <Path Classes="footer-icon-path"
                    Data="M4,7 V17 L10,21 L20,11 L13,4 H7 A3,3 0 0 0 4,7 Z M8,8.5 A1.5,1.5 0 1 1 8,11.5 A1.5,1.5 0 1 1 8,8.5 Z" />
            </Border>
            <StackPanel Grid.Column="1"
                        Spacing="1"
                        VerticalAlignment="Center">
              <TextBlock Classes="footer-label" Text="VERSION" />
              <TextBlock x:Name="VersionText"
                         Classes="footer-value"
                         Width="96"
                         Text="{Binding VersionText}" />
            </StackPanel>
          </Grid>
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   IsVisible="False"
                   Text="{Binding StatusText}" />
      </Grid>
    </Border>
  </Grid>
</shadui:Window>
